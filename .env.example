# .env.example
# This file serves as a template for your environment variables.
# Copy this file to .env and fill in your actual keys.
# DO NOT commit your .env file to Git.

# Gemini API Key: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# App URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL="YOUR_APP_URL"

# Add other third-party API keys here as needed:
# STRIPE_SECRET_KEY="sk_test_..."
# FIREBASE_API_KEY="AIza..."
# DATABASE_URL="postgresql://..."
