{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"], "description": "The user's role in the platform." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email"]
    },
    "Material": {
      "title": "Learning Material",
      "description": "Represents a PDF document and its extracted content.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the PDF." },
        "extractedText": { "type": "string", "description": "The full text extracted from the PDF." },
        "chunks": { "type": "array", "items": { "type": "string" }, "description": "The text divided into smaller chunks." },
        "topics": { "type": "array", "items": { "type": "string" }, "description": "List of topics identified in the material." },
        "creatorId": { "type": "string", "description": "The UID of the user who uploaded the material." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the material was uploaded." }
      },
      "required": ["title", "creatorId"]
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "Records a user's performance on a quiz.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who took the quiz." },
        "materialId": { "type": "string", "description": "The ID of the material the quiz was based on." },
        "topic": { "type": "string", "description": "The topic of the quiz." },
        "score": { "type": "number", "description": "The number of correct answers." },
        "total": { "type": "number", "description": "The total number of questions." },
        "percentage": { "type": "number", "description": "The score as a percentage." },
        "date": { "type": "string", "format": "date-time", "description": "When the quiz was taken." }
      },
      "required": ["userId", "materialId", "score", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Learning materials uploaded by users."
    },
    "/quizAttempts/{attemptId}": {
      "schema": "QuizAttempt",
      "description": "Individual quiz performance records."
    }
  }
}
